if ! command -v bun >/dev/null 2>&1; then
  for candidate in "${HOME:-}/.bun/bin" "/home/vscode/.bun/bin" "/root/.bun/bin"; do
    if [ -x "$candidate/bun" ]; then
      export PATH="$candidate:$PATH"
      break
    fi
  done
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun not found in PATH for pre-commit hook" >&2
  exit 127
fi

bun run lint-staged
bun run test
