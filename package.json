{
  "name": "db_nebengeld_frontend",
  "version": "2.0.0",
  "description": "",
  "private": "true",
  "scripts": {
    "start": "bunx --bun vite --host",
    "test": "tsc && vitest run",
    "build": "bunx --bun vite build",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "lint-staged": "lint-staged",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "preview": "bunx --bun vite preview --outDir=../public/public",
    "dev-test": "vitest --ui --api 9527",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": [
      "bun run lint"
    ]
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@types/bootstrap": "^5.2.10",
    "@types/file-saver": "^2.0.7",
    "@types/jsdom": "^28.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-inject-preload": "^3.0.0",
    "vite": "^8.0.0",
    "vite-plugin-compression2": "^2.5.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "vitest-fail-on-console": "^0.10.1",
    "vitest-fetch-mock": "^0.4.5"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "dayjs": "^1.11.20",
    "feiertagejs": "^1.5.0",
    "file-saver": "^2.0.5",
    "material-icons": "^1.13.14",
    "preact": "^10.29.0"
  }
}
