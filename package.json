{
  "name": "db_nebengeld_frontend",
  "version": "2.3.0",
  "description": "",
  "private": "true",
  "scripts": {
    "start": "bunx --bun vite --host",
    "test": "TZ=Europe/Berlin bun test --isolate",
    "build": "bunx --bun vite build",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "lint-staged": "lint-staged",
    "lint": "bunx --bun eslint src/ test/",
    "lint:fix": "bunx --bun eslint src/ test/ --fix",
    "lint:files": "bunx --bun eslint",
    "preview": "bunx --bun vite preview --outDir=../public/public",
    "dev-test": "TZ=Europe/Berlin bun test --isolate --watch",
    "coverage": "TZ=Europe/Berlin bun test --isolate --coverage",
    "release:check": "bun run lint && bun run test && bun run build",
    "release": "bun run release:patch",
    "release:patch": "bun run release:check && bun ./scripts/release.ts patch",
    "release:minor": "bun run release:check && bun ./scripts/release.ts minor",
    "release:major": "bun run release:check && bun ./scripts/release.ts major",
    "deploy": "bun run deploy:main",
    "deploy:main": "bash ./scripts/deploy.sh",
    "deploy:main:dry": "bash ./scripts/deploy.sh --dry-run",
    "deploy:main:skip-checks": "bash ./scripts/deploy.sh --skip-checks",
    "release:deploy": "bun run release:deploy:patch",
    "release:deploy:patch": "bun run release:check && bun ./scripts/release.ts patch --commit --push && bun run deploy:main:skip-checks",
    "release:deploy:minor": "bun run release:check && bun ./scripts/release.ts minor --commit --push && bun run deploy:main:skip-checks",
    "release:deploy:major": "bun run release:check && bun ./scripts/release.ts major --commit --push && bun run deploy:main:skip-checks",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "bun run lint:files --"
    ]
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.10.1",
    "@preact/preset-vite": "^2.10.5",
    "@types/bootstrap": "^5.2.11",
    "@types/bun": "^1.3.14",
    "@types/file-saver": "^2.0.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "unplugin-inject-preload": "^3.0.0",
    "vite": "^8.0.16",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@simplewebauthn/browser": "^13.3.0",
    "bootstrap": "^5.3.8",
    "dayjs": "^1.11.21",
    "dayjs-feiertage": "^0.1.0",
    "file-saver": "^2.0.5",
    "material-icons": "^1.13.14",
    "preact": "^10.29.2",
    "uuid": "^14.0.0"
  }
}
